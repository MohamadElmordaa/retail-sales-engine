# Copy to .env and fill from the Neon Console -> Connect.
# Any PostgreSQL 16+ connection string works; Neon is what we developed against.
# NEVER commit a real .env — the connection string is a live credential.

# POOLED — has "-pooler" in the hostname. Goes through PgBouncer.
# Used by the running application (src/prisma/prisma.service.ts) at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require&connect_timeout=15&pool_timeout=15"

# DIRECT — no "-pooler". Bypasses PgBouncer.
# Used by the Prisma CLI (prisma.config.ts): migrate, db seed, studio, introspect.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require&connect_timeout=15"

PORT=3000
BASE_CURRENCY=USD
